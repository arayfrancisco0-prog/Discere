      "duration": 25,
      "order_num": 1,
      "created_at": "2026-06-13 02:42:58"
    },
    {
      "id": "0ebd8060-9202-4dbd-81cd-4a23715fe992",
      "module_id": "0624caa6-8b5c-4db1-b215-81d4cfd989ea",
      "title": "Herança e Polimorfismo",
      "content": "<p>Herança permite que uma classe herde atributos de outra.</p>",
      "video_url": null,
      "duration": 25,
      "order_num": 2,
      "created_at": "2026-06-13 02:42:58"
    },
    {
      "id": "02bd9afb-088a-44b1-9ddc-c1bda1c46b3c",
      "module_id": "0624caa6-8b5c-4db1-b215-81d4cfd989ea",
      "title": "Projeto Final",
      "content": "<p>Crie um sistema de biblioteca usando POO.</p>",
