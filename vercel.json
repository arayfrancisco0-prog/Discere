{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/", "dest": "public/index.html" },
    { "src": "/api/(.*)", "dest": "api/index.js" },
    { "src": "/css/(.*)", "dest": "public/css/$1" },
    { "src": "/js/(.*)", "dest": "public/js/$1" },
    { "src": "/uploads/(.*)", "dest": "uploads/$1" },
    { "src": "/(.*\\.html)", "dest": "public/$1" },
    { "src": "/(.*)", "dest": "api/index.js" }
  ]
}
